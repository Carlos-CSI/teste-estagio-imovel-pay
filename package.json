{
  "name": "teste-estagio-imovel-pay",
  "version": "1.0.0",
  "description": "Projeto full-Stack para gerenciar cobranças",
  "main": "index.js",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "iniciate":"npm i && npm run iniciate -w backend",
    "start": "concurrently --names \"frontend,backend\" \"npm start -w frontend\" \"npm start -w backend\" ",
    "dev": "concurrently --names \"frontend,backend\" \"npm start -w frontend\" \"npm run dev -w backend\" "
  },
  "author": "Felipe Mejias",
  "license": "ISC",
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}